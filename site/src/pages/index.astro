---
import Base from '../layouts/Base.astro';
import { projects } from '../data/projects';
import manifest from '../data/manifest.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function previewFor(project) {
  const slug = project.selectsDir
    ? project.selectsDir.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')
    : project.slug;
  const m = manifest[slug];
  if (!m) return null;
  const first = m.assets.find(a => a.type === 'image' && a.outputs.some(o => o.includes('-1200.webp')));
  if (!first) return null;
  const webp = first.outputs.find(o => o.includes('-1200.webp'));
  return `${base}/media/${webp}`;
}
---
<Base>
  <section class="index">
    <h1 class="index-intro">
      Senior Producer<br />
      <em>specializing in commercial<br />production — motion &amp; stills.</em>
    </h1>

    <div class="list-head">
      <span class="num"></span>
      <span class="th">Client</span>
      <span class="th">Category</span>
      <span class="th">Format</span>
    </div>

    <ol class="project-list" id="project-list">
      {projects.map((p, i) => {
        const preview = previewFor(p);
        const num = String(i + 1).padStart(2, '0');
        return (
          <li class="project-li">
            <a
              href={`${base}/projects/${p.slug}/`}
              class="project-row"
              data-preview={preview ?? ''}
            >
              <span class="num">{num}</span>
              <span class="title">{p.client}</span>
              <span class="cat">{p.category}</span>
              <span class="format">{p.format ?? ''}</span>
            </a>
          </li>
        );
      })}
    </ol>
  </section>

  <div class="preview-pane" id="preview"><img id="preview-img" alt="" /></div>

  <script>
    const pane = document.getElementById('preview');
    const img = document.getElementById('preview-img');
    document.querySelectorAll('.project-row').forEach(row => {
      const src = row.getAttribute('data-preview');
      if (!src) return;
      row.addEventListener('pointerenter', () => { img.src = src; pane.classList.add('on'); });
      row.addEventListener('pointerleave', () => pane.classList.remove('on'));
    });
  </script>
</Base>
